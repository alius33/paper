# Path to the git repository (absolute path)
# Development: /home/user/paper
# Railway: /workspace/repo
REPO_PATH=/home/user/paper

# Git remote URL (with token for push/pull on Railway)
# GIT_REPO_URL=https://<github_token>@github.com/alius33/paper.git

# Git branch (default: main)
GIT_BRANCH=main
